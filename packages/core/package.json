{
	"name": "@infra-ts/core",
	"version": "0.5.0",
	"description": "The infra-ts open standard: the provider contract, defineConfig, typed env, and the REST/diff/state primitives every infra-ts provider builds on.",
	"keywords": [
		"infra-ts",
		"iac",
		"infrastructure-as-code",
		"config-as-code",
		"typescript",
		"live-reconciled"
	],
	"license": "Apache-2.0",
	"author": "Andre Landgraf <andre@neon.tech>",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean --sourcemap",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"engines": {
		"node": ">=20"
	}
}
