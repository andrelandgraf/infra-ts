{
	"name": "@infra-ts/stripe-projects",
	"version": "0.5.0",
	"description": "infra-ts provider for Stripe Projects — declare infra that Stripe Projects provisions across providers, driven through the Stripe CLI.",
	"keywords": [
		"infra-ts",
		"stripe",
		"stripe-projects",
		"provisioning",
		"provider"
	],
	"license": "Apache-2.0",
	"author": "Andre Landgraf <andre@neon.tech>",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean --sourcemap --tsconfig tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@infra-ts/core": "0.5.0",
		"zod": "^4.0.0"
	},
	"engines": {
		"node": ">=20"
	}
}
