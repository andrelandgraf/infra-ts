{
	"name": "@infra-ts/neon",
	"version": "0.5.0",
	"description": "infra-ts provider for Neon — manage Neon projects, branches and compute as typed, live-reconciled config-as-code (no attribute state).",
	"keywords": [
		"infra-ts",
		"neon",
		"postgres",
		"iac",
		"provider"
	],
	"license": "Apache-2.0",
	"author": "Andre Landgraf <andre@neon.tech>",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean --sourcemap --tsconfig tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@infra-ts/core": "0.5.0",
		"esbuild": "^0.24.0",
		"fflate": "^0.8.2",
		"zod": "^4.0.0"
	},
	"engines": {
		"node": ">=20"
	}
}
