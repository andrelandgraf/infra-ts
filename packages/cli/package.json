{
	"name": "infra-ts",
	"version": "0.4.1",
	"description": "infra-ts — typed, live-reconciled infrastructure & config as code (no attribute state). An infra.ts file, a thin REST provider system, and a CLI/SDK for Neon, Vercel and beyond.",
	"keywords": [
		"infra-ts",
		"iac",
		"infrastructure-as-code",
		"config-as-code",
		"neon",
		"vercel",
		"typescript",
		"cli"
	],
	"license": "Apache-2.0",
	"author": "Andre Landgraf <andre@neon.tech>",
	"type": "module",
	"bin": {
		"infra-ts": "dist/cli.js",
		"infra": "dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./neon": {
			"types": "./dist/neon.d.ts",
			"import": "./dist/neon.js"
		},
		"./vercel": {
			"types": "./dist/vercel.d.ts",
			"import": "./dist/vercel.js"
		},
		"./upstash": {
			"types": "./dist/upstash.d.ts",
			"import": "./dist/upstash.js"
		},
		"./resend": {
			"types": "./dist/resend.d.ts",
			"import": "./dist/resend.js"
		},
		"./mux": {
			"types": "./dist/mux.d.ts",
			"import": "./dist/mux.js"
		},
		"./sentry": {
			"types": "./dist/sentry.d.ts",
			"import": "./dist/sentry.js"
		},
		"./workos": {
			"types": "./dist/workos.d.ts",
			"import": "./dist/workos.js"
		},
		"./sanity": {
			"types": "./dist/sanity.d.ts",
			"import": "./dist/sanity.js"
		},
		"./statsig": {
			"types": "./dist/statsig.d.ts",
			"import": "./dist/statsig.js"
		},
		"./dub": {
			"types": "./dist/dub.d.ts",
			"import": "./dist/dub.js"
		},
		"./stripe": {
			"types": "./dist/stripe.d.ts",
			"import": "./dist/stripe.js"
		},
		"./posthog": {
			"types": "./dist/posthog.d.ts",
			"import": "./dist/posthog.js"
		},
		"./elevenlabs": {
			"types": "./dist/elevenlabs.d.ts",
			"import": "./dist/elevenlabs.js"
		},
		"./openai": {
			"types": "./dist/openai.d.ts",
			"import": "./dist/openai.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "bun src/cli.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@clack/prompts": "^0.9.1",
		"chalk": "^5.4.1",
		"commander": "^13.1.0",
		"esbuild": "^0.24.0",
		"fflate": "^0.8.2",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"@infra-ts/core": "0.4.1",
		"@infra-ts/dub": "0.4.1",
		"@infra-ts/elevenlabs": "0.4.1",
		"@infra-ts/mux": "0.4.1",
		"@infra-ts/neon": "0.4.1",
		"@infra-ts/openai": "0.4.1",
		"@infra-ts/posthog": "0.4.1",
		"@infra-ts/resend": "0.4.1",
		"@infra-ts/runtime": "0.4.1",
		"@infra-ts/sanity": "0.4.1",
		"@infra-ts/sentry": "0.4.1",
		"@infra-ts/statsig": "0.4.1",
		"@infra-ts/stripe": "0.4.1",
		"@infra-ts/upstash": "0.4.1",
		"@infra-ts/vercel": "0.4.1",
		"@infra-ts/workos": "0.4.1"
	},
	"engines": {
		"node": ">=20"
	}
}
