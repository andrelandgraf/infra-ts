{
	"name": "@infra-ts/posthog",
	"version": "0.3.2",
	"description": "infra-ts provider for PostHog — projects and feature flags as typed, live-reconciled config-as-code.",
	"keywords": [
		"infra-ts",
		"posthog",
		"analytics",
		"feature-flags",
		"provider"
	],
	"license": "Apache-2.0",
	"author": "Andre Landgraf <andre@neon.tech>",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean --sourcemap --tsconfig tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@infra-ts/core": "0.3.2",
		"zod": "^4.0.0"
	},
	"engines": {
		"node": ">=20"
	}
}
